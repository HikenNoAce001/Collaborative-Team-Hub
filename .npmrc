# pnpm settings.
# Hoist all @prisma/* packages so the generated Prisma client at
# apps/api/src/generated/prisma/ can resolve transitive runtime deps
# (e.g. @prisma/client-runtime-utils, @prisma/debug) via flat lookup.
# Without this, pnpm nests them under @prisma/client/node_modules/ and
# Node's require() from outside that subtree can't find them.
public-hoist-pattern[]=*@prisma/*

# Strict peer-dep resolution — fail loudly when a workspace forgets a peer.
strict-peer-dependencies=false
