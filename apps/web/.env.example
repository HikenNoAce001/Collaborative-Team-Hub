# Team Hub — Web environment.
# Copy to apps/web/.env.local for local dev. Railway injects these in production.

# Base API URL — server components fetch directly; axios uses the public one with credentials.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Brand metadata
NEXT_PUBLIC_APP_NAME="Team Hub"
