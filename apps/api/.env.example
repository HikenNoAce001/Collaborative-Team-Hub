# Team Hub — API environment.
# Copy to apps/api/.env for local dev. Railway injects these in production.

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database — local docker-compose default; Railway Postgres plugin overrides this.
DATABASE_URL=postgresql://team_hub:team_hub_dev@localhost:5432/team_hub?schema=public

# Auth — generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-32-byte-hex
JWT_REFRESH_SECRET=replace-with-different-32-byte-hex
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS / cookies — must match the deployed web origin in production
CLIENT_URL=http://localhost:3000
COOKIE_DOMAIN=

# Cloudinary — avatars + announcement images. Sign up at cloudinary.com (free tier).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (bonus: email invitations). Falls back to console.log if unset.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Team Hub <no-reply@team-hub.local>"

# Misc
RATE_LIMIT_AUTH_PER_MIN=10
ENABLE_SWAGGER=true
