{
  "name": "@team-hub/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Team Hub backend — Express 5 + Prisma 7 + Socket.io.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "build": "echo 'api build is a no-op (interpreted node, prisma generate runs separately)' && exit 0",
    "start": "node src/server.js",
    "lint": "eslint .",
    "test": "node --test --env-file=.env",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node --env-file=.env prisma/seed.js",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "node --env-file=.env prisma/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@team-hub/schemas": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@team-hub/eslint-config": "workspace:*",
    "dotenv": "^16.6.1",
    "prisma": "^7.8.0"
  }
}
