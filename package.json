{
  "name": "team-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Collaborative Team Hub — full-stack workspace (FredoCloud Technical Assessment).",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{js,jsx,mjs,cjs,json,md,yml,yaml,prisma}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,cjs,json,md,yml,yaml,prisma}\"",
    "db:migrate": "pnpm --filter @team-hub/api db:migrate",
    "db:seed": "pnpm --filter @team-hub/api db:seed",
    "db:generate": "pnpm --filter @team-hub/api db:generate",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.7"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.1"
}
